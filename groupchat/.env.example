# ── 火山引擎 TTS 凭证 (必填) ──────────────
# 申请: https://console.volcengine.com/
VOLC_APPID=your_app_id_here
VOLC_TOKEN=your_token_here

# ── 每个偶像的克隆声音 ID ─────────────
# 规则: VOLC_<SLUG 大写>_SPEAKER_ID = 这个偶像的 speaker_id
# slug 是你 /create-idol 时用的目录名 (~/.config/idol-skill/idols/<slug>/)
# 没有克隆声音? 看姊妹技能 voice-clone 教你从公开音视频复刻
#
# 示例 (根据自己的 idol slug 改):
# VOLC_IDOL_A_SPEAKER_ID=S_xxxx
# VOLC_IDOL_B_SPEAKER_ID=S_yyyy

# ── 默认 speaker (可选) ────────────
# 所有没单独配 VOLC_<SLUG>_SPEAKER_ID 的偶像会回落到这个
# VOLC_SPEAKER_ID=S_default

# ── 偶像数据目录 (可选, 默认 ~/.config/idol-skill/idols) ───
# IDOL_DATA_DIR=/path/to/idols

# ── 共享对话文件路径 (可选, 默认 /tmp/idol_groupchat.txt) ───
# GROUPCHAT_FILE=/tmp/idol_groupchat.txt
