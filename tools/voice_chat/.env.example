# ── 火山引擎（豆包 TTS 声音复刻）──────────────────────
# https://console.volcengine.com/speech → 音频生成 → 声音复刻 2.0
VOLC_APPID=your_appid_here
VOLC_TOKEN=your_token_here

# 可选：兜底预设声音类型
VOLC_VOICE_TYPE=zh_male_M392_conversation_wvae_bigtts

# 可选：全局兜底 speaker_id（没有偶像专属 speaker 时用）
VOLC_SPEAKER_ID=

# ── 偶像专属声线 ─────────────────────────────────────
# 命名规则：
#   默认：         VOLC_{SLUG_UPPER}_SPEAKER_ID
#   多状态：       VOLC_{SLUG_UPPER}_SPEAKER_ID       (default/day 状态)
#                  VOLC_{SLUG_UPPER}_NIGHT_SPEAKER_ID (夜晚状态，需 voice_chat.json 配置)
#
# slug 转大写，`-` 替换成 `_`。例如偶像 slug=yangbaiwan：
#   VOLC_YANGBAIWAN_SPEAKER_ID=S_xxxxxxxx           # 白天/默认
#   VOLC_YANGBAIWAN_NIGHT_SPEAKER_ID=S_xxxxxxxx     # 夜晚温柔版（可选）
